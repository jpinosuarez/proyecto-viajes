{
  "name": "proyecto-viajes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "emulators:start:persist": "firebase emulators:start --only auth,firestore,storage --project keeptrip-app-b06b3 --import ./.emulator-data --export-on-exit",
    "emulators:exec:persist": "firebase emulators:exec --only auth,firestore,storage --project keeptrip-app-b06b3 --import ./.emulator-data --export-on-exit",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting,firestore:rules,storage --project staging",
    "deploy:prod": "npm run build && firebase deploy --only hosting,firestore:rules,storage --project default",
    "deploy:staging:hosting": "npm run build:staging && firebase deploy --only hosting --project staging",
    "deploy:prod:hosting": "npm run build && firebase deploy --only hosting --project default",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:staging": "vite preview --mode staging",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'e2e/**' --exclude 'src/__tests__/firestore.rules.test.js'",
    "test:rules": "vitest run src/__tests__/firestore.rules.test.js",
    "test:e2e": "firebase emulators:exec --only auth,firestore,storage --project keeptrip-app-b06b3 \"npx playwright test\"",
    "test:ci": "vitest run && playwright test",
    "audit:performance": "node scripts/run-lighthouse.mjs"
  },
  "dependencies": {
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "dom-to-image-more": "^3.7.2",
    "firebase": "^12.8.0",
    "framer-motion": "^12.29.2",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.563.0",
    "mapbox-gl": "^3.18.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.6",
    "react-map-gl": "^7.1.7",
    "react-router-dom": "^6.30.3",
    "react-simple-maps": "^3.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "world-countries": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.41.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "vite": "npm:rolldown-vite@7.2.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
