rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isFounder() {
      return isAuthenticated()
        && request.auth.uid in [
          'f8a2ANPUI4VW8SOzUmcJtFumOFSm',
          'jXpeKNBz9YjRyHm5LFWIANCIpGv3',
          '8qWhUsYQBXO3bCiMXen8qiIYAUA2',
          '9dyI5iXXJRSTwO350Vnv3utZff52'
        ];
    }

    match /system/operational_flags {
      allow read: if true;
      allow write: if isFounder();
    }

    match /usuarios/{userId} {
      allow read, write: if isOwner(userId);

      match /viajes/{viajeId} {
        
        function hasAccess() {
          let invId = viajeId + "_" + request.auth.uid;
          return isOwner(userId)
            || (isAuthenticated() && resource != null && 'sharedWith' in resource.data && resource.data.sharedWith != null && request.auth.uid in resource.data.sharedWith)
            || (
              isAuthenticated() &&
              exists(/databases/$(database)/documents/invitations/$(invId)) &&
              get(/databases/$(database)/documents/invitations/$(invId)).data.status == 'accepted'
            );
        }

        allow read: if hasAccess();
        allow create: if isOwner(userId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(userId);
        allow update: if isOwner(userId)
          || (
            hasAccess() 
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWith'])
          );

        match /{coleccion}/{docId=**} {
          function hasParentAccess() {
            let parentPath = /databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId);
            let parentData = getAfter(parentPath).data;
            let invId = viajeId + "_" + request.auth.uid;
            return isOwner(userId)
              || (parentData != null && 'sharedWith' in parentData && parentData.sharedWith != null && request.auth.uid in parentData.sharedWith)
              || (
                isAuthenticated() && 
                existsAfter(/databases/$(database)/documents/invitations/$(invId)) &&
                getAfter(/databases/$(database)/documents/invitations/$(invId)).data.status == 'accepted'
              );
          }

          allow read: if hasParentAccess();
          allow write: if hasParentAccess();
        }
      }
    }

    match /invitations/{invId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAuthenticated() && (
        invId.matches('.*_' + request.auth.uid)
        || (resource != null && 'inviterId' in resource.data && request.auth.uid == resource.data.inviterId)
        || (resource != null && 'inviteeUid' in resource.data && request.auth.uid == resource.data.inviteeUid)
      );
    }

    match /paises_info/{paisCode} {
      allow read: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
