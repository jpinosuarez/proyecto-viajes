rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /usuarios/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /usuarios/{userId}/viajes/{viajeId} {
      allow read: if isOwner(userId)
        || (
          isAuthenticated()
          && (
            (request.auth.uid in resource.data.get('sharedWith', []))
            || (
              exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid))
              && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid)).data.status == 'accepted'
            )
          )
        );

      allow create, delete: if isOwner(userId);

      allow update: if isOwner(userId)
        || (
          isAuthenticated()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['sharedWith'])
          && request.auth.uid in request.resource.data.get('sharedWith', [])
          && exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid))
          && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid)).data.status == 'accepted'
        );
    }

    match /usuarios/{userId}/viajes/{viajeId} {
      allow read: if isAuthenticated();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /usuarios/{userId}/viajes/{viajeId}/invitations/{inviteeUid} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == inviteeUid);
    }

    match /usuarios/{userId}/viajes/{viajeId}/{subDocument=**} {
      allow read: if isOwner(userId)
        || (
          isAuthenticated()
          && (
            (request.auth.uid in resource.data.get('sharedWith', []))
            || (
              exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid))
              && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid)).data.status == 'accepted'
            )
          )
        );
      allow write: if isOwner(userId);
    }

    match /usuarios/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /invitations/{invId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        ('inviterId' in resource.data && request.auth.uid == resource.data.inviterId) || 
        ('inviteeUid' in resource.data && request.auth.uid == resource.data.inviteeUid)
      );
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && ('inviterId' in resource.data && request.auth.uid == resource.data.inviterId);
    }

    match /paises_info/{paisCode} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
