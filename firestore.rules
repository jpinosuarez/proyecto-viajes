rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /usuarios/{userId} {
      allow read, write: if isOwner(userId);

      match /viajes/{viajeId} {

        function isSharedWithMe() {
          return isAuthenticated()
            && exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId))
            && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)).data.sharedWith is list
            && request.auth.uid in get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)).data.sharedWith;
        }

        function isInvitationAccepted() {
          return isAuthenticated()
            && exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid)).data.status == 'accepted';
        }

        allow read: if isOwner(userId) || isSharedWithMe() || isInvitationAccepted();
        allow create: if isOwner(userId) && request.resource.data.ownerId == request.auth.uid;
        allow delete: if isOwner(userId);

        allow update: if isOwner(userId)
          || (
            (isSharedWithMe() || isInvitationAccepted())
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['titulo', 'ownerId'])
          );

        match /{coleccion}/{docId=**} {
          function isParentSharedWithMe() {
            let parentData = get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)).data;
            return isOwner(userId)
              || (parentData.sharedWith is list && request.auth.uid in parentData.sharedWith)
              || (
                exists(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid))
                && get(/databases/$(database)/documents/usuarios/$(userId)/viajes/$(viajeId)/invitations/$(request.auth.uid)).data.status == 'accepted'
              );
          }

          allow read: if isParentSharedWithMe();
          allow write: if isParentSharedWithMe();
        }
      }
    }

    match /invitations/{invId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        ('inviterId' in resource.data && request.auth.uid == resource.data.inviterId)
        || ('inviteeUid' in resource.data && request.auth.uid == resource.data.inviteeUid)
      );
      allow update: if isAuthenticated() && (
        ('inviterId' in resource.data && request.auth.uid == resource.data.inviterId)
        || ('inviteeUid' in resource.data && request.auth.uid == resource.data.inviteeUid)
      );
      allow delete: if isAuthenticated() && ('inviterId' in resource.data && request.auth.uid == resource.data.inviterId);
    }

    match /paises_info/{paisCode} {
      allow read: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
